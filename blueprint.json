{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/",
    "preferredPhpVersion": "8.1",
    "steps": [
        {
            "step": "login",
            "username": "admin",
            "password": "password"
        },
        {
            "step": "installTheme",
            "themeData": {
                "resource": "url",
                "url": "https://github.com/xarop/xarop-theme/archive/refs/heads/main.zip"
            },
            "options": {
                "activate": true
            }
        },
        {
            "step": "installPlugin",
            "pluginData": {
                "resource": "wordpress.org/plugins/gutenberg"
            }
        },
        {
            "step": "setSiteOptions",
            "options": {
                "blogname": "Xarop Demo",
                "blogdescription": "Probando el starter kit de xarop.com",
                "WPLANG": "ca"
            }
        },
        {
            "step": "writeFiles",
            "files": {
                "wp-content/themes/xarop-theme-main/theme-config.php": "<?php return [ 'colors' => [ 'primary' => '#ee2455' ], 'gutenberg_enabled' => true ]; ?>"
            }
        }
    ]
}